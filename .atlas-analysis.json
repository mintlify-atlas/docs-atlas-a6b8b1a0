  "keyFeatures": [
    "Multi-platform follower scraping (Instagram, TikTok, X, Threads)",
    "Gender-based profile filtering and detection",
    "Daily campaign management with 14,400 profile batches",
    "Automated VA distribution across 80 Airtable tables",
    "Real-time progress tracking and campaign history",
    "Multi-tenant job isolation with base_id",
    "Supabase integration for data persistence",
    "Automated profile deduplication"
  ],
  "publicApiSurface": [
    "POST /api/scrape-followers - Scrape Instagram followers",
    "POST /api/ingest - Ingest profiles into database",
    "POST /api/daily-selection - Create campaign and select profiles",
    "POST /api/distribute/{campaign_id} - Distribute profiles to VA tables",
    "POST /api/airtable-sync/{campaign_id} - Sync profiles to Airtable",
    "POST /api/cleanup - Cleanup old campaigns",
    "createScrapingJob() - Create new scraping job",
    "getJobsByPlatform() - Get jobs by platform",
    "getActiveJob() - Get active scraping job",
    "getJobStatistics() - Get job statistics",
    "updateJobStatus() - Update job status"
  ]
